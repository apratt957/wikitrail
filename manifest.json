{
  "manifest_version": 3,
  "name": "WikiTrail",
  "description": "Map your Wikipedia rabbit holes",
  "version": "1.0",
  "permissions": ["tabs", "storage", "activeTab", "contextMenus"],
  "host_permissions": ["*://*.wikipedia.org/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/wikitrail-icon-16.png",
    "48": "icons/wikitrail-icon-48.png",
    "128": "icons/wikitrail-icon-128.png"
  }
}
